MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1428419150}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1f2b84e25a8041c1b0bde4ccfe7c6f12, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  questions:
  - prompt: 
    imageTexture: {fileID: 2800000, guid: e989931e111d63c4f948987c88eac0ac, type: 3}
    hintText: Look for the Manila park area associated with the Rizal Monument.
    factText: The correct answer is Luneta. This image points to Manila's historic
      Rizal Park area.
    correctIndex: 2
    options:
    - Intramuros
    - Binondo
    - Luneta
    - National Museum
  - prompt: 
    imageTexture: {fileID: 2800000, guid: 7af5fd7061ac762488017345409ff4e5, type: 3}
    hintText: This landmark is the park area best known for the Rizal Monument.
    factText: The correct answer is Luneta. This historic Manila park is widely known
      today as Rizal Park.
    correctIndex: 1
    options:
    - Intramuros
    - Luneta
    - Binondo
    - National Museum
  - prompt: 
    imageTexture: {fileID: 2800000, guid: 0494f1985c04e2a429f0bff71d284f10, type: 3}
    hintText: This walled city is one of the oldest historic districts in Manila.
    factText: The correct answer is Intramuros. It is the historic Spanish-era walled
      city in Manila.
    correctIndex: 0
    options:
    - Intramuros
    - Luneta
    - Binondo
    - National Museum
  - prompt: 
    imageTexture: {fileID: 2800000, guid: 3502c4fecee3d3c4cb58c5828fe8c1e6, type: 3}
    hintText: This district is famous for Chinese-Filipino culture, food, and trade.
    factText: The correct answer is Binondo. It is known as the oldest Chinatown
      in the world.
    correctIndex: 2
    options:
    - Intramuros
    - Luneta
    - Binondo
    - National Museum
  - prompt: 
    imageTexture: {fileID: 2800000, guid: f4e34233765cbf448b94f1a374d3eb17, type: 3}
    hintText: This landmark houses important collections of art, anthropology, and
      natural history.
    factText: The correct answer is National Museum. It is one of Manila's best-known
      cultural landmarks.
    correctIndex: 3
    options:
    - Intramuros
    - Luneta
    - Binondo
    - National Museum
