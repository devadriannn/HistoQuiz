  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "During the Philippine Revolution against Spanish rule, Melchora Aquino
    played an important role in supporting Filipino revolutionaries. She opened her
    home to wounded soldiers, giving them food, shelter, and medical care. Because
    of her selfless service, she became known as \u201CTandang Sora\u201D and was
    called the \u201CMother of the Katipunan.\u201D Her bravery and support inspired
    many revolutionaries to continue fighting for freedom, even though helping them
    put her own life at risk."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
  m_sharedMaterial: {fileID: 2140474, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
