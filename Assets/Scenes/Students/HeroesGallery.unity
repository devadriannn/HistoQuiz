  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The victory at Mactan became a historic moment, marking the first successful
    resistance against foreign invaders in the Philippines. Lapu-Lapu\u2019s bravery
    symbolizes the Filipino spirit of independence and courage. Today, he is honored
    as a national hero, representing strength, leadership, and the willingness to
    fight for freedom and sovereignty."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
