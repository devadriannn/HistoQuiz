  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "During the revolution, conflicts arose within the revolutionary government,
    leading to disagreements between Bonifacio and other leaders. He was later arrested
    and accused of treason. In 1897, Andres Bonifacio was executed in Maragondon,
    Cavite. Although his life ended tragically, his bravery and willingness to fight
    for freedom made him one of the greatest heroes of the Philippines. Today, he
    is remembered as a symbol of courage, leadership, and the Filipino people\u2019s
    struggle for independence."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
