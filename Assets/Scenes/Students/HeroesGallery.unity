  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "As Spanish oppression in the Philippines continued, Bonifacio believed
    that peaceful reform was not enough to achieve freedom. Inspired by the ideas
    of nationalism, he founded the Katipunan, a secret revolutionary society that
    aimed to gain independence from Spain through armed struggle. He became known
    as the \u201CFather of the Philippine Revolution\u201D because of his leadership
    and courage. In 1896, Bonifacio led the movement that sparked the revolution,
    including the historic Cry of Pugad Lawin, where Filipinos tore their cedulas
    as a sign of resistance against Spanish rule."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
  m_sharedMaterial: {fileID: 2140474, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
