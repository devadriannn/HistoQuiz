  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Jos\xE9 Rizal was born on June 19, 1861, in Calamba, Laguna, into a well-educated
    Filipino family that valued learning and discipline. From a young age, he showed
    remarkable intelligence, learning to read early and developing a passion for
    writing and education. His mother, Teodora Alonso, served as his first teacher
    and greatly influenced his intellectual growth. Rizal studied in Bi\xF1an, Laguna,
    and later at Ateneo Municipal de Manila, where he excelled academically. He continued
    his studies at the University of Santo Tomas, but due to discrimination from
    Spanish professors, he decided to pursue further education abroad."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
  m_sharedMaterial: {fileID: 2140474, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
