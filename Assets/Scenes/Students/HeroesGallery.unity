  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Due to her involvement with the revolutionaries, Melchora Aquino was arrested
    by Spanish authorities and exiled to Guam. Even in exile, she remained strong
    and hopeful for her country\u2019s independence. After several years, she was
    allowed to return to the Philippines, where she lived peacefully until her death
    on February 19, 1919. Today, Melchora Aquino is remembered as a symbol of courage,
    sacrifice, and patriotism, whose kindness greatly contributed to the fight for
    freedom."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
