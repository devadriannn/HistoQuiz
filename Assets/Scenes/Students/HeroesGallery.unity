  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "In April 1521, Magellan attempted to assert his power over Mactan, but
    Lapu-Lapu resisted. This led to the Battle of Mactan on April 27, 1521. Lapu-Lapu
    and his warriors fought bravely using their knowledge of the terrain and local
    combat strategies. Despite the advanced weapons of the Spanish forces, Lapu-Lapu\u2019s
    leadership and courage led to the defeat of Magellan, who was killed during the
    battle."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
  m_sharedMaterial: {fileID: 2140474, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
