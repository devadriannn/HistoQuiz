  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Mabini\u2019s life changed when he suffered from paralysis, which left
    him unable to walk. Despite this condition, he remained mentally strong and continued
    to serve his country. During the revolution, he became the chief adviser of Emilio
    Aguinaldo and played a key role in organizing the revolutionary government. Because
    of his intelligence and influence, he was called the \u201CBrains of the Revolution.\u201D
    Mabini emphasized the importance of proper governance, discipline among leaders,
    and unity among Filipinos in achieving true independence."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
