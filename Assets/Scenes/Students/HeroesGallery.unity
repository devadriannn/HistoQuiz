  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: Emilio Aguinaldo was born on March 22, 1869, in Kawit, Cavite, into a family
    that was relatively well-off compared to many Filipinos of his time. From a young
    age, he showed leadership qualities and became involved in community affairs.
    As Spanish oppression continued, Aguinaldo joined the Katipunan, a secret revolutionary
    society that aimed to gain independence from Spain. Through his bravery and strategic
    thinking, he quickly rose to a leadership position within the revolutionary movement.
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
  m_sharedMaterial: {fileID: 2140474, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
