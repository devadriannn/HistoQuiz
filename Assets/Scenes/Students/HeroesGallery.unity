  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Rizal traveled to Spain and studied at the Universidad Central de Madrid,
    where he became a doctor specializing in ophthalmology, aiming to treat his mother\u2019s
    eye condition. During his time in Europe, he also studied in France and Germany,
    gaining knowledge and learning multiple languages. While abroad, Rizal became
    more aware of the injustices experienced by Filipinos under Spanish colonial
    rule. Instead of using violence, he chose to fight through his writings. He wrote
    Noli Me Tangere and El Filibusterismo, novels that exposed the abuses of Spanish
    authorities and awakened a sense of nationalism among Filipinos."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
  m_sharedMaterial: {fileID: 2140474, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
